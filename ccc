# ── Helpers ──────────────────────────────────────────────────────────────────
die()  { printf "${RED}error:${RESET} %s\n" "$*" >&2; exit 1; }
info() { printf "${CYAN}▸${RESET} %s\n" "$*"; }
warn() { printf "${YELLOW}warning:${RESET} %s\n" "$*" >&2; }
ok()   { printf "${GREEN}✓${RESET} %s\n" "$*"; }

check_jq() {
  command -v jq &>/dev/null || die "jq is required. Install: brew install jq (macOS) / apt install jq (Linux)"
}

check_sqlite() {
  command -v sqlite3 &>/dev/null || die "sqlite3 is required for cc-switch mode."
}

HAS_GUM=false
check_gum() { command -v gum &>/dev/null && [[ -t 1 ]] && HAS_GUM=true || true; }

# ── Gum Helpers ────────────────────────────────────────────────────────────
gum_pick_provider() {
  local names=()
  while IFS= read -r n; do
    [[ -z "$n" ]] && continue
    names+=("$n")
  done < <(get_all_names)
  [[ ${#names[@]} -eq 0 ]] && die "no providers found"
  gum filter --placeholder="${L_SELECT_PROVIDER}" "${names[@]}"
}

