# ── Mode Detection ───────────────────────────────────────────────────────────
detect_mode() {
  if [[ -n "${FLAG_MODE:-}" ]]; then
    echo "$FLAG_MODE"
  elif [[ -n "${CCC_MODE:-}" ]]; then
    echo "$CCC_MODE"
  elif [[ -f "$CCC_CONFIG" ]]; then
    local m
    m=$(jq -r '.mode // "auto"' "$CCC_CONFIG" 2>/dev/null)
    if [[ "$m" != "auto" && -n "$m" ]]; then
      echo "$m"; return
    fi
    # auto: fall through
    if [[ -f "$CC_SWITCH_DB" ]]; then echo "ccswitch"; else echo "standalone"; fi
  elif [[ -f "$CC_SWITCH_DB" ]]; then
    echo "ccswitch"
  else
    echo "standalone"
  fi
}

# ── Fuzzy Name Resolution ───────────────────────────────────────────────────
# Populates RESOLVED_NAME with the matched name, or dies on ambiguity/miss.
RESOLVED_NAME=""

get_all_names() {
  if [[ "$MODE" == "ccswitch" ]]; then
    sqlite3 "$CC_SWITCH_DB" "SELECT name FROM providers WHERE app_type='$APP_TYPE' ORDER BY sort_index;"
  else
    if [[ -d "$CCC_PROFILES" ]]; then
      for f in "$CCC_PROFILES"/*.json; do
        [[ -f "$f" ]] || continue
        jq -r '.name // empty' "$f" 2>/dev/null
      done
    fi
  fi
}

resolve_name() {
  local input="$1"
  local input_lower
  input_lower=$(printf '%s' "$input" | tr '[:upper:]' '[:lower:]')
  local -a exact=() prefix=()
  while IFS= read -r n; do
    [[ -z "$n" ]] && continue
    local n_lower
    n_lower=$(printf '%s' "$n" | tr '[:upper:]' '[:lower:]')
    # exact (case-insensitive)
    if [[ "$n_lower" == "$input_lower" ]]; then
      exact+=("$n")
    # prefix (case-insensitive)
    elif [[ "$n_lower" == "$input_lower"* ]]; then
      prefix+=("$n")
    fi
  done < <(get_all_names)

  if [[ ${#exact[@]} -eq 1 ]]; then
    RESOLVED_NAME="${exact[0]}"; return
  elif [[ ${#exact[@]} -gt 1 ]]; then
    printf "${RED}error:${RESET} ambiguous name '%s', matches:\n" "$input" >&2
    printf "  %s\n" "${exact[@]}" >&2; exit 1
  fi

  if [[ ${#prefix[@]} -eq 1 ]]; then
    RESOLVED_NAME="${prefix[0]}"; return
  elif [[ ${#prefix[@]} -gt 1 ]]; then
    printf "${RED}error:${RESET} ambiguous prefix '%s', matches:\n" "$input" >&2
    printf "  %s\n" "${prefix[@]}" >&2; exit 1
  fi

  die "no provider matching '$input'"
}

# ── cc-switch DB Helpers ─────────────────────────────────────────────────────
ccsw_get_config() {
  local name="$1"
  sqlite3 "$CC_SWITCH_DB" \
    "SELECT settings_config FROM providers WHERE app_type='$APP_TYPE' AND name='$name' LIMIT 1;"
}

ccsw_get_id() {
  local name="$1"
  sqlite3 "$CC_SWITCH_DB" \
    "SELECT id FROM providers WHERE app_type='$APP_TYPE' AND name='$name' LIMIT 1;"
}

ccsw_get_current_name() {
  sqlite3 "$CC_SWITCH_DB" \
    "SELECT name FROM providers WHERE app_type='$APP_TYPE' AND is_current=1 LIMIT 1;"
}

# ── Standalone Helpers ───────────────────────────────────────────────────────
sa_profile_path() {
  echo "$CCC_PROFILES/$1.json"
}

sa_get_current_name() {
  if [[ -f "$CCC_CONFIG" ]]; then
    jq -r '.current // empty' "$CCC_CONFIG" 2>/dev/null
  fi
}

sa_build_overlay() {
  local file="$1"
  jq '{env: .env, model: .model} | with_entries(select(.value != null))' "$file"
}

sa_ensure_dir() {
  [[ -d "$CCC_PROFILES" ]] || mkdir -p "$CCC_PROFILES"
}

# ── Backup ───────────────────────────────────────────────────────────────────
backup_settings() {
  [[ -f "$CLAUDE_SETTINGS" ]] || return 0
  mkdir -p "$BACKUP_DIR"
  local ts
  ts=$(date +%s)000
  cp "$CLAUDE_SETTINGS" "$BACKUP_DIR/.claude.json.backup.$ts"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_list() {
  local current_name=""
  if [[ "$MODE" == "ccswitch" ]]; then
    current_name=$(ccsw_get_current_name)
    if $HAS_GUM; then
      local table_data=""
      table_data+=$' \tNAME\tBASE_URL\tMODEL\n'
      sqlite3 -separator '|' "$CC_SWITCH_DB" \
        "SELECT name,
                json_extract(settings_config, '\$.env.ANTHROPIC_BASE_URL'),
                json_extract(settings_config, '\$.env.ANTHROPIC_MODEL')
         FROM providers WHERE app_type='$APP_TYPE' ORDER BY sort_index;" \
      | while IFS='|' read -r name url model; do
        local marker=" "
        [[ "$name" == "$current_name" ]] && marker="→"
        local short_url="${url#http://}"
        short_url="${short_url#https://}"
        printf '%s\t%s\t%s\t%s\n' "$marker" "$name" "$short_url" "$model"
      done | { table_data+=$(cat); echo "$table_data" | gum table -s $'\t'; }
    else
      printf "${BOLD}  %-18s %-36s %s${RESET}\n" "NAME" "BASE_URL" "MODEL"
      sqlite3 -separator '|' "$CC_SWITCH_DB" \
        "SELECT name,
                json_extract(settings_config, '\$.env.ANTHROPIC_BASE_URL'),
                json_extract(settings_config, '\$.env.ANTHROPIC_MODEL')
         FROM providers WHERE app_type='$APP_TYPE' ORDER BY sort_index;" \
      | while IFS='|' read -r name url model; do
        local marker="  "
        [[ "$name" == "$current_name" ]] && marker="${GREEN}→${RESET} "
        local short_url="${url#http://}"
        short_url="${short_url#https://}"
        printf "$marker${BOLD}%-18s${RESET} ${DIM}%-36s${RESET} %s\n" "$name" "$short_url" "$model"
      done
    fi
  else
    current_name=$(sa_get_current_name)
    if [[ ! -d "$CCC_PROFILES" ]] || ! compgen -G "$CCC_PROFILES/*.json" &>/dev/null; then
      info "No profiles found. Create one with: ccc add <name>"
      return
    fi
    if $HAS_GUM; then
      local table_data
      table_data=$' \tNAME\tBASE_URL\tMODEL\n'
      for f in "$CCC_PROFILES"/*.json; do
        [[ -f "$f" ]] || continue
        local name url model
        name=$(jq -r '.name // empty' "$f")
        url=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$f")
        model=$(jq -r '.env.ANTHROPIC_MODEL // ""' "$f")
        [[ -z "$name" ]] && continue
        local marker=" "
        [[ "$name" == "$current_name" ]] && marker="→"
        local short_url="${url#http://}"
        short_url="${short_url#https://}"
        table_data+=$(printf '%s\t%s\t%s\t%s\n' "$marker" "$name" "$short_url" "$model")
        table_data+=$'\n'
      done
      echo "$table_data" | gum table -s $'\t'
    else
      printf "${BOLD}  %-18s %-36s %s${RESET}\n" "NAME" "BASE_URL" "MODEL"
      for f in "$CCC_PROFILES"/*.json; do
        [[ -f "$f" ]] || continue
        local name url model
        name=$(jq -r '.name // empty' "$f")
        url=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$f")
        model=$(jq -r '.env.ANTHROPIC_MODEL // ""' "$f")
        [[ -z "$name" ]] && continue
        local marker="  "
        [[ "$name" == "$current_name" ]] && marker="${GREEN}→${RESET} "
        local short_url="${url#http://}"
        short_url="${short_url#https://}"
        printf "$marker${BOLD}%-18s${RESET} ${DIM}%-36s${RESET} %s\n" "$name" "$short_url" "$model"
      done
    fi
  fi
}

cmd_current() {
  if [[ "$MODE" == "ccswitch" ]]; then
    local name url model
    read -r name url model < <(sqlite3 -separator ' ' "$CC_SWITCH_DB" \
      "SELECT name,
              json_extract(settings_config, '\$.env.ANTHROPIC_BASE_URL'),
              json_extract(settings_config, '\$.env.ANTHROPIC_MODEL')
       FROM providers WHERE app_type='$APP_TYPE' AND is_current=1 LIMIT 1;")
    if [[ -z "$name" ]]; then
      warn "no active provider"; return 1
    fi
    printf "${GREEN}→${RESET} ${BOLD}%s${RESET}\n" "$name"
    printf "  base_url: %s\n" "$url"
    printf "  model:    %s\n" "$model"
  else
    local name
    name=$(sa_get_current_name)
    if [[ -z "$name" ]]; then
      warn "no active profile. Use 'ccc switch <name>' to set one."; return 1
    fi
    local file
    file=$(sa_profile_path "$name")
    if [[ ! -f "$file" ]]; then
      warn "profile '$name' recorded as current but file missing"; return 1
    fi
    local url model
    url=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$file")
    model=$(jq -r '.env.ANTHROPIC_MODEL // ""' "$file")
    printf "${GREEN}→${RESET} ${BOLD}%s${RESET}\n" "$name"
    printf "  base_url: %s\n" "$url"
    printf "  model:    %s\n" "$model"
  fi
}

cmd_show() {
  if [[ ${#@} -lt 1 ]]; then
    if $HAS_GUM; then
      local picked
      picked=$(gum_pick_provider) || return
      set -- "$picked"
    else
      die "usage: ccc show <name>"
    fi
  fi
  resolve_name "$1"
  local name="$RESOLVED_NAME"

  if [[ "$MODE" == "ccswitch" ]]; then
    local config
    config=$(ccsw_get_config "$name")
    [[ -z "$config" ]] && die "provider '$name' not found"
    printf "${BOLD}%s${RESET}\n" "$name"
    # show env fields with token masked
    echo "$config" | jq -r '.env // {} | to_entries[] | "  \(.key): \(.value)"' \
      | sed -E 's/(ANTHROPIC_AUTH_TOKEN: ).{4}(.{4})/\1****\2/'
    local model_alias
    model_alias=$(echo "$config" | jq -r '.model // empty')
    if [[ -n "$model_alias" ]]; then printf "  model_alias: %s\n" "$model_alias"; fi
  else
    local file
    file=$(sa_profile_path "$name")
    [[ -f "$file" ]] || die "profile '$name' not found"
    printf "${BOLD}%s${RESET}\n" "$name"
    local desc
    desc=$(jq -r '.description // empty' "$file")
    [[ -n "$desc" ]] && printf "  description: %s\n" "$desc"
    jq -r '.env // {} | to_entries[] | "  \(.key): \(.value)"' "$file" \
      | sed -E 's/(ANTHROPIC_AUTH_TOKEN: ).{4}(.{4})/\1****\2/'
    local model_alias
    model_alias=$(jq -r '.model // empty' "$file")
    if [[ -n "$model_alias" ]]; then printf "  model_alias: %s\n" "$model_alias"; fi
  fi
}

cmd_use() {
  if [[ ${#@} -lt 1 ]]; then
    if $HAS_GUM; then
      local picked
      picked=$(gum_pick_provider) || return
      set -- "$picked"
    else
      die "usage: ccc use <name> [-- claude-args...]"
    fi
  fi
  resolve_name "$1"; shift
  local name="$RESOLVED_NAME"

  # Collect remaining args (skip -- separator if present)
  local -a claude_args=()
  for arg in "$@"; do
    [[ "$arg" == "--" ]] && continue
    claude_args+=("$arg")
  done

  local tmpfile
  tmpfile=$(mktemp /tmp/ccc-XXXXXXXX)
  mv "$tmpfile" "$tmpfile.json"
  tmpfile="$tmpfile.json"
  trap "rm -f '$tmpfile'" EXIT

  if [[ "$MODE" == "ccswitch" ]]; then
    local config
    config=$(ccsw_get_config "$name")
    [[ -z "$config" ]] && die "provider '$name' not found"
    echo "$config" > "$tmpfile"
  else
    local file
    file=$(sa_profile_path "$name")
    [[ -f "$file" ]] || die "profile '$name' not found"
    sa_build_overlay "$file" > "$tmpfile"
  fi

  info "launching claude with profile '${name}'"
  if [[ ${#claude_args[@]} -eq 0 ]]; then
    exec claude --settings "$tmpfile"
  else
    exec claude --settings "$tmpfile" "${claude_args[@]}"
  fi
}

cmd_switch() {
  if [[ ${#@} -lt 1 ]]; then
    if $HAS_GUM; then
      local picked
      picked=$(gum_pick_provider) || return
      set -- "$picked"
    else
      die "usage: ccc switch <name>"
    fi
  fi
  resolve_name "$1"
  local name="$RESOLVED_NAME"

  if [[ "$MODE" == "ccswitch" ]]; then
    local config provider_id
    config=$(ccsw_get_config "$name")
    [[ -z "$config" ]] && die "provider '$name' not found"
    provider_id=$(ccsw_get_id "$name")

    # backup
    backup_settings

    # write settings.json
    echo "$config" > "$CLAUDE_SETTINGS"

    # update database is_current
    sqlite3 "$CC_SWITCH_DB" \
      "UPDATE providers SET is_current=0 WHERE app_type='$APP_TYPE';
       UPDATE providers SET is_current=1 WHERE app_type='$APP_TYPE' AND id='$provider_id';"

    # update cc-switch settings
    if [[ -f "$CC_SWITCH_SETTINGS" ]]; then
      local tmp
      tmp=$(mktemp)
      jq --arg id "$provider_id" '.currentProviderClaude = $id' "$CC_SWITCH_SETTINGS" > "$tmp" \
        && mv "$tmp" "$CC_SWITCH_SETTINGS"
    fi

    ok "switched to '${name}'"
  else
    local file
    file=$(sa_profile_path "$name")
    [[ -f "$file" ]] || die "profile '$name' not found"

    # backup
    backup_settings

    if [[ -f "$CLAUDE_SETTINGS" ]]; then
      # merge env and model into existing settings.json
      local overlay
      overlay=$(sa_build_overlay "$file")
      local tmp
      tmp=$(mktemp)
      jq --argjson overlay "$overlay" '
        . as $base |
        if $overlay.env then .env = ($base.env // {} | . * $overlay.env) else . end |
        if $overlay.model then .model = $overlay.model else . end
      ' "$CLAUDE_SETTINGS" > "$tmp" && mv "$tmp" "$CLAUDE_SETTINGS"
    else
      # no existing settings, create from overlay
      mkdir -p "$(dirname "$CLAUDE_SETTINGS")"
      sa_build_overlay "$file" > "$CLAUDE_SETTINGS"
    fi

    # record current profile
    mkdir -p "$CCC_DIR"
    if [[ -f "$CCC_CONFIG" ]]; then
      local tmp
      tmp=$(mktemp)
      jq --arg name "$name" '.current = $name' "$CCC_CONFIG" > "$tmp" && mv "$tmp" "$CCC_CONFIG"
    else
      printf '{"mode":"auto","current":"%s"}\n' "$name" > "$CCC_CONFIG"
    fi

    ok "switched to '${name}'"
  fi
}

cmd_add() {
  [[ "$MODE" != "standalone" ]] && die "'add' is only available in standalone mode. Manage providers in cc-switch GUI."
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    if $HAS_GUM; then
      name=$(gum input --placeholder "$L_PROFILE_NAME" --header "$L_PROFILE_NAME") || return
      [[ -z "$name" ]] && die "name is required"
    else
      die "usage: ccc add <name>"
    fi
  fi
  sa_ensure_dir
  local file
  file=$(sa_profile_path "$name")
  [[ -f "$file" ]] && die "profile '$name' already exists. Use 'ccc edit $name' to modify."

  local desc="" base_url="" token="" model="" haiku="" opus="" sonnet="" reasoning="" model_alias=""

  if $HAS_GUM; then
    gum style --bold --foreground 212 "$L_CREATING_PROFILE: $name"
    echo

    desc=$(gum input --placeholder "$L_DESC_PH" --header "$L_DESC") || true
    base_url=$(gum input --placeholder "https://api.example.com" --header "ANTHROPIC_BASE_URL${L_REQUIRED}") || return
    [[ -z "$base_url" ]] && die "base_url is required"
    token=$(gum input --placeholder "sk-xxx" --header "ANTHROPIC_AUTH_TOKEN${L_REQUIRED}" --password) || return
    [[ -z "$token" ]] && die "auth_token is required"
    model=$(gum input --placeholder "claude-sonnet-4-6" --header "ANTHROPIC_MODEL${L_REQUIRED}") || return
    [[ -z "$model" ]] && die "model is required"

    gum style --faint "$L_ENTER_DEFAULT '$model'"
    read -r -t 0.1 -n 10000 2>/dev/null || true
    haiku=$(gum input --placeholder "$model" --header "ANTHROPIC_DEFAULT_HAIKU_MODEL") || true
    opus=$(gum input --placeholder "$model" --header "ANTHROPIC_DEFAULT_OPUS_MODEL") || true
    sonnet=$(gum input --placeholder "$model" --header "ANTHROPIC_DEFAULT_SONNET_MODEL") || true
    reasoning=$(gum input --placeholder "$model" --header "ANTHROPIC_REASONING_MODEL") || true
    model_alias=$(gum input --placeholder "$L_MODEL_ALIAS_PH" --header "$L_MODEL_ALIAS") || true
  else
    printf "${BOLD}Creating profile: %s${RESET}\n" "$name"
    read -rp "Description (optional): " desc
    read -rp "ANTHROPIC_BASE_URL: " base_url
    [[ -z "$base_url" ]] && die "base_url is required"
    read -rp "ANTHROPIC_AUTH_TOKEN: " token
    [[ -z "$token" ]] && die "auth_token is required"
    read -rp "ANTHROPIC_MODEL: " model
    [[ -z "$model" ]] && die "model is required"
    read -rp "ANTHROPIC_DEFAULT_HAIKU_MODEL (Enter = $model): " haiku
    read -rp "ANTHROPIC_DEFAULT_OPUS_MODEL (Enter = $model): " opus
    read -rp "ANTHROPIC_DEFAULT_SONNET_MODEL (Enter = $model): " sonnet
    read -rp "ANTHROPIC_REASONING_MODEL (Enter = $model): " reasoning
    read -rp "model alias (e.g. opus[1m], Enter to skip): " model_alias
  fi

  [[ -z "$haiku" ]] && haiku="$model"
  [[ -z "$opus" ]] && opus="$model"
  [[ -z "$sonnet" ]] && sonnet="$model"
  [[ -z "$reasoning" ]] && reasoning="$model"

  local json_content
  json_content=$(jq -n \
    --arg name "$name" \
    --arg desc "$desc" \
    --arg base_url "$base_url" \
    --arg token "$token" \
    --arg model "$model" \
    --arg haiku "$haiku" \
    --arg opus "$opus" \
    --arg sonnet "$sonnet" \
    --arg reasoning "$reasoning" \
    --arg model_alias "$model_alias" \
    '{
      name: $name,
      description: (if $desc != "" then $desc else null end),
      env: {
        ANTHROPIC_BASE_URL: $base_url,
        ANTHROPIC_AUTH_TOKEN: $token,
        ANTHROPIC_MODEL: $model,
        ANTHROPIC_DEFAULT_HAIKU_MODEL: $haiku,
        ANTHROPIC_DEFAULT_OPUS_MODEL: $opus,
        ANTHROPIC_DEFAULT_SONNET_MODEL: $sonnet,
        ANTHROPIC_REASONING_MODEL: $reasoning
      },
      model: (if $model_alias != "" then $model_alias else null end)
    } | with_entries(select(.value != null))')

  if $HAS_GUM; then
    echo
    gum style --border double --border-foreground 212 --padding "1 2" --bold "$L_PROFILE_PREVIEW"
    # show with token masked
    echo "$json_content" | jq '.' | sed -E 's/("ANTHROPIC_AUTH_TOKEN": ").{4}(.{4}")/\1****\2/'
    echo
    gum confirm "$L_SAVE_CONFIRM" || { info "$L_CANCELLED"; return; }
  fi

  echo "$json_content" > "$file"

  ok "profile '$name' created at $file"
}

cmd_edit() {
  [[ "$MODE" != "standalone" ]] && die "'edit' is only available in standalone mode."
  if [[ ${#@} -lt 1 ]]; then
    if $HAS_GUM; then
      local picked
      picked=$(gum_pick_provider) || return
      set -- "$picked"
    else
      die "usage: ccc edit <name>"
    fi
  fi
  resolve_name "$1"
  local name="$RESOLVED_NAME"
  local file
  file=$(sa_profile_path "$name")
  [[ -f "$file" ]] || die "profile '$name' not found"

  local editor="${EDITOR:-vi}"
  "$editor" "$file"
  # validate JSON
  if ! jq empty "$file" 2>/dev/null; then
    warn "file is not valid JSON after editing"
  else
    ok "profile '$name' updated"
  fi
}

cmd_rm() {
  [[ "$MODE" != "standalone" ]] && die "'rm' is only available in standalone mode."
  if [[ ${#@} -lt 1 ]]; then
    if $HAS_GUM; then
      local picked
      picked=$(gum_pick_provider) || return
      set -- "$picked"
    else
      die "usage: ccc rm <name>"
    fi
  fi
  resolve_name "$1"
  local name="$RESOLVED_NAME"
  local file
  file=$(sa_profile_path "$name")
  [[ -f "$file" ]] || die "profile '$name' not found"

  if $HAS_GUM; then
    gum confirm "$L_REMOVE_CONFIRM '$name'?" || { info "$L_CANCELLED"; return; }
  else
    read -rp "Remove profile '$name'? [y/N] " confirm
    [[ "$confirm" =~ ^[yY]$ ]] || { info "cancelled"; return; }
  fi
  rm "$file"

  # clear current if it was this profile
  if [[ -f "$CCC_CONFIG" ]]; then
    local cur
    cur=$(jq -r '.current // empty' "$CCC_CONFIG")
    if [[ "$cur" == "$name" ]]; then
      local tmp
      tmp=$(mktemp)
      jq 'del(.current)' "$CCC_CONFIG" > "$tmp" && mv "$tmp" "$CCC_CONFIG"
    fi
  fi

  ok "profile '$name' removed"
}

cmd_import() {
  [[ "$MODE" != "standalone" ]] && die "'import' is only available in standalone mode."
  [[ ! -f "$CLAUDE_SETTINGS" ]] && die "no settings.json found at $CLAUDE_SETTINGS"
  sa_ensure_dir

  local name="${1:-}"
  if [[ -z "$name" ]]; then
    # derive name from base_url hostname
    local url
    url=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$CLAUDE_SETTINGS")
    if [[ -n "$url" ]]; then
      name=$(echo "$url" | sed -E 's|https?://||; s|[:/].*||')
      # sanitize
      name=$(echo "$name" | tr -c 'a-zA-Z0-9._-' '-')
    fi
    [[ -z "$name" ]] && die "cannot derive name from settings. Provide one: ccc import <name>"
  fi

  local file
  file=$(sa_profile_path "$name")
  [[ -f "$file" ]] && die "profile '$name' already exists"

  jq '{
    name: "'$name'",
    env: (.env // {}),
    model: (.model // null)
  } | with_entries(select(.value != null))' "$CLAUDE_SETTINGS" > "$file"

  ok "imported current settings as profile '$name'"
}


# ── TUI ──────────────────────────────────────────────────────────────────────

tui_rows() { tput lines 2>/dev/null || echo 24; }

tui_pause() {
  echo
  gum input --placeholder "$L_PRESS_ENTER" > /dev/null 2>&1 || true
}

tui_vtop() {
  local content_lines="${1:-12}"
  local rows; rows=$(tui_rows)
  local top=$(( (rows - content_lines) / 3 ))
  [[ $top -lt 1 ]] && top=1
  for ((i=0; i<top; i++)); do echo; done
}

# Pad string to target display width (CJK-aware via wc -L)
tui_rpad() {
  local text="$1" target="$2"
  local dw; dw=$(printf '%s' "$text" | wc -L)
  local need=$(( target - dw ))
  (( need < 0 )) && need=0
  printf '%s%*s' "$text" "$need" ""
}

tui_choose() {
  gum choose --header "$1" "${@:2}"
}

tui_provider_info() {
  local cur_name=""
  if [[ "$MODE" == "ccswitch" ]]; then
    cur_name=$(ccsw_get_current_name)
  else
    cur_name=$(sa_get_current_name)
  fi
  if [[ -n "$cur_name" ]]; then
    local file url
    if [[ "$MODE" == "ccswitch" ]]; then
      url=$(sqlite3 "$CC_SWITCH_DB" \
        "SELECT json_extract(settings_config, '\$.env.ANTHROPIC_BASE_URL') FROM providers WHERE app_type='$APP_TYPE' AND name='$cur_name' LIMIT 1;")
    else
      file=$(sa_profile_path "$cur_name")
      url=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$file" 2>/dev/null)
    fi
    local short_url="${url#http://}"
    short_url="${short_url#https://}"
    echo "$cur_name ($short_url)"
  else
    echo "$L_NONE"
  fi
}

tui_logo() {
  gum style --align center --foreground 99 --bold \
    '  ___  ___  ___  ' \
    ' / __)/ __)/ __) ' \
    '( (__( (__( (__  ' \
    ' \___)\___)\___) '
  gum style --align center --foreground 240 "v${VERSION}"
}

# sub-menu: provider management
tui_providers() {
  while true; do
    clear
    tui_vtop 22

    gum style --align center --bold --foreground 141 \
      --border rounded --border-foreground 240 --padding "0 4" \
      "  $L_PROVIDERS"
    echo
    cmd_list
    echo

    local -a choices=(
      "$L_VIEW_DETAILS"
      "$L_SWITCH_GLOBAL"
      "$L_USE_SESSION"
    )
    if [[ "$MODE" == "standalone" ]]; then
      choices+=(
        "$L_ADD_PROVIDER"
        "$L_EDIT_PROVIDER"
        "$L_REMOVE_PROVIDER"
        "$L_IMPORT_SETTINGS"
      )
    fi
    choices+=("$L_BACK")

    local choice
    choice=$(tui_choose "$L_SELECT_ACTION" "${choices[@]}") || break

    case "$choice" in
      "$L_VIEW_DETAILS")
        local picked; picked=$(gum_pick_provider) || continue
        echo; cmd_show "$picked"; tui_pause ;;
      "$L_SWITCH_GLOBAL")
        local picked; picked=$(gum_pick_provider) || continue
        cmd_switch "$picked"; tui_pause ;;
      "$L_USE_SESSION")
        local picked; picked=$(gum_pick_provider) || continue
        cmd_use "$picked" ;;
      "$L_ADD_PROVIDER")
        cmd_add; tui_pause ;;
      "$L_EDIT_PROVIDER")
        local picked; picked=$(gum_pick_provider) || continue
        cmd_edit "$picked"; tui_pause ;;
      "$L_REMOVE_PROVIDER")
        local picked; picked=$(gum_pick_provider) || continue
        cmd_rm "$picked"; tui_pause ;;
      "$L_IMPORT_SETTINGS")
        cmd_import; tui_pause ;;
      "$L_BACK"|"") break ;;
    esac
  done
}

# sub-menu: settings
tui_settings() {
  while true; do
    clear
    tui_vtop 18

    gum style --align center --bold --foreground 141 \
      --border rounded --border-foreground 240 --padding "0 4" \
      "⚙  $L_SETTINGS"
    echo

    local lang_display="English"
    [[ "$CCC_LANG" == "zh" ]] && lang_display="中文"

    gum style --padding "0 2" \
      "$(tui_rpad "$L_MODE_LABEL" 14) :  $MODE" \
      "$(tui_rpad "$L_CONFIG_PATH" 14) :  $CCC_CONFIG" \
      "$(tui_rpad "$L_PROFILES_DIR" 14) :  $CCC_PROFILES" \
      "$(tui_rpad "$L_LANG_LABEL" 14) :  $lang_display"
    echo

    local -a choices=(
      "$L_SWITCH_MODE (current: $MODE)"
      "$L_SWITCH_LANG ($lang_display)"
      "$L_OPEN_CONFIG"
      "$L_BACK"
    )

    local choice
    choice=$(tui_choose "$L_SELECT_ACTION" "${choices[@]}") || break

    case "$choice" in
      "$L_SWITCH_MODE"*)
        local new_mode
        new_mode=$(gum choose --header "$L_SELECT_MODE (current: $MODE)" "auto" "standalone" "ccswitch") || continue
        mkdir -p "$CCC_DIR"
        if [[ -f "$CCC_CONFIG" ]]; then
          local tmp; tmp=$(mktemp)
          jq --arg m "$new_mode" '.mode = $m' "$CCC_CONFIG" > "$tmp" && mv "$tmp" "$CCC_CONFIG"
        else
          printf '{"mode":"%s"}\n' "$new_mode" > "$CCC_CONFIG"
        fi
        MODE=$(detect_mode)
        ok "$L_MODE_SET '$new_mode' ($L_EFFECTIVE: $MODE)"
        tui_pause ;;
      "$L_SWITCH_LANG"*)
        local new_lang
        new_lang=$(gum choose --header "$L_SELECT_LANG" "English" "中文") || continue
        [[ "$new_lang" == "中文" ]] && new_lang="zh" || new_lang="en"
        mkdir -p "$CCC_DIR"
        if [[ -f "$CCC_CONFIG" ]]; then
          local tmp; tmp=$(mktemp)
          jq --arg l "$new_lang" '.lang = $l' "$CCC_CONFIG" > "$tmp" && mv "$tmp" "$CCC_CONFIG"
        else
          printf '{"mode":"auto","lang":"%s"}\n' "$new_lang" > "$CCC_CONFIG"
        fi
        load_lang
        ok "$L_LANG_SET '$new_lang'"
        tui_pause ;;
      "$L_OPEN_CONFIG"*)
        local editor="${EDITOR:-vi}"
        if [[ -f "$CCC_CONFIG" ]]; then
          "$editor" "$CCC_CONFIG"
        else
          warn "$L_NO_CONFIG"
          mkdir -p "$CCC_DIR"
          printf '{"mode":"auto"}\n' > "$CCC_CONFIG"
          "$editor" "$CCC_CONFIG"
        fi ;;
      "$L_BACK"|"") break ;;
    esac
  done
}

cmd_tui() {
  $HAS_GUM || die "TUI requires gum. Install: brew install gum / go install github.com/charmbracelet/gum@latest"

  while true; do
    clear
    tui_vtop 16

    tui_logo
    echo

    local provider_info
    provider_info=$(tui_provider_info)

    gum style --foreground 212 \
      --border rounded --border-foreground 99 --padding "1 3" \
      "$(tui_rpad "$L_PROVIDER" 10) :  $provider_info" \
      "$(tui_rpad "$L_MODE" 10) :  $MODE" \
      "$(tui_rpad "$L_APP" 10) :  $APP_TYPE"
    echo

    local choice
    choice=$(tui_choose "$L_MAIN_HEADER" \
      "$L_MANAGE_PROVIDERS" \
      "$L_VIEW_CURRENT" \
      "$L_SETTINGS_MENU" \
      "$L_EXIT") || break

    case "$choice" in
      "$L_MANAGE_PROVIDERS") tui_providers ;;
      "$L_VIEW_CURRENT")
        echo; cmd_current; tui_pause ;;
      "$L_SETTINGS_MENU") tui_settings ;;
      "$L_EXIT"|"") break ;;
    esac
  done
}

# ── Help ─────────────────────────────────────────────────────────────────────
show_help() {
  cat <<EOF
${BOLD}ccc${RESET} v${VERSION} — Claude Code Change

${BOLD}USAGE${RESET}
  ccc [command] [options]

${BOLD}COMMANDS${RESET}
  list                  List all providers/profiles
  use <name> [-- args]  Launch claude with the given profile (no global change)
  switch <name>         Switch globally (writes to settings.json)
  current               Show the active provider
  show <name>           Show provider details
  tui                   Interactive TUI menu (requires gum)

  ${DIM}Standalone mode only:${RESET}
  add <name>            Create a new profile interactively
  edit <name>           Edit a profile with \$EDITOR
  rm <name>             Remove a profile
  import [name]         Import current settings.json as a profile

${BOLD}OPTIONS${RESET}
  --standalone          Force standalone mode
  --cc-switch           Force cc-switch mode
  -h, --help            Show this help
  -v, --version         Show version

${BOLD}MODE${RESET}
  Auto-detects cc-switch database (~/.cc-switch/cc-switch.db).
  Override: CCC_MODE=standalone|ccswitch, or ~/.config/ccc/config.json

${BOLD}EXAMPLES${RESET}
  ccc                       List providers
  ccc use kirors             Launch claude with 'kirors' provider
  ccc use ki -- -c           Launch with prefix match, continue last session
  ccc switch CPA             Switch globally to 'CPA'
  ccc add my-proxy           Create a new standalone profile
  ccc import                 Save current config as a profile
EOF
}

# ── Main ─────────────────────────────────────────────────────────────────────
main() {
  FLAG_MODE=""
  local cmd=""
  local -a args=()

  # Parse global flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --standalone) FLAG_MODE="standalone"; shift ;;
      --cc-switch)  FLAG_MODE="ccswitch"; shift ;;
      -h|--help)    show_help; exit 0 ;;
      -v|--version) echo "ccc v${VERSION}"; exit 0 ;;
      -*)           die "unknown option: $1" ;;
      *)
        if [[ -z "$cmd" ]]; then cmd="$1"; else args+=("$1"); fi
        shift ;;
    esac
  done

  check_jq
  check_gum
  MODE=$(detect_mode)
  load_lang
  [[ "$MODE" == "ccswitch" ]] && check_sqlite

  # Default command: TUI if gum available, otherwise list
  if [[ -z "$cmd" ]]; then
    if $HAS_GUM; then
      cmd="tui"
    else
      cmd="list"
    fi
  fi

  case "$cmd" in
    list)    cmd_list ;;
    use)     cmd_use "${args[@]}" ;;
    switch)  cmd_switch "${args[@]}" ;;
    current) cmd_current ;;
    show)    cmd_show "${args[@]}" ;;
    add)     cmd_add "${args[@]}" ;;
    edit)    cmd_edit "${args[@]}" ;;
    rm)      cmd_rm "${args[@]}" ;;
    import)  cmd_import "${args[@]}" ;;
    tui)     cmd_tui ;;
    *)       die "unknown command: $cmd. Run 'ccc --help' for usage." ;;
  esac
}

main "$@"
